{
    "id" : "dev.neikon.kinetic_sol",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "command" : "kineticsol",
    "finish-args" : [
        "--share=network",
        "--system-talk-name=org.freedesktop.login1",
        "--talk-name=org.kde.StatusNotifierWatcher",
        "--own-name=org.kde.StatusNotifierItem.dev.neikon.kinetic_sol",
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules" : [
        {
            "name" : "kineticsol",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "dir",
                    "path" : ".",
                    "skip" : [
                        ".git",
                        ".github",
                        ".flatpak-builder",
                        "_build",
                        "builddir",
                        "repo"
                    ]
                }
            ]
        }
    ]
}
