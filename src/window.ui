<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="Adw" version="1.0"/>
  <object class="GtkAdjustment" id="port_adjustment">
    <property name="lower">1024</property>
    <property name="upper">65535</property>
    <property name="step-increment">1</property>
    <property name="page-increment">10</property>
    <property name="value">39721</property>
  </object>
  <template class="KineticsolWindow" parent="AdwApplicationWindow">
    <property name="title" translatable="yes">KineticSOL</property>
    <property name="default-width">760</property>
    <property name="default-height">820</property>
    <property name="content">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <child type="end">
              <object class="GtkMenuButton">
                <property name="primary">True</property>
                <property name="icon-name">open-menu-symbolic</property>
                <property name="tooltip-text" translatable="yes">Main Menu</property>
                <property name="menu-model">primary_menu</property>
              </object>
            </child>
          </object>
        </child>
        <property name="content">
          <object class="AdwToastOverlay" id="toast_overlay">
            <property name="child">
              <object class="GtkScrolledWindow">
                <property name="hscrollbar-policy">never</property>
                <property name="child">
                  <object class="AdwClamp">
                    <property name="maximum-size">780</property>
                    <property name="tightening-threshold">520</property>
                    <property name="child">
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">24</property>
                        <property name="margin-top">24</property>
                        <property name="margin-bottom">24</property>
                        <property name="margin-start">18</property>
                        <property name="margin-end">18</property>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">8</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="xalign">0</property>
                                <property name="label" translatable="yes">Linux shutdown bridge for Kinetic WOL</property>
                                <style>
                                  <class name="title-2"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel">
                                <property name="xalign">0</property>
                                <property name="wrap">True</property>
                                <property name="label" translatable="yes">This app listens on the local network, validates a shared token and tries to power off the machine through logind without using interactive sudo.</property>
                                <style>
                                  <class name="dim-label"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Remote Access</property>
                            <property name="description" translatable="yes">KineticSOL always starts its local HTTP listener when the app launches and keeps it available until the app exits.</property>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Run in background</property>
                                <property name="subtitle" translatable="yes">When enabled, closing the window hides KineticSOL instead of exiting while the remote listener stays available.</property>
                                <property name="activatable-widget">background_switch</property>
                                <child type="suffix">
                                  <object class="GtkSwitch" id="background_switch">
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Start hidden in tray</property>
                                <property name="subtitle" translatable="yes">When enabled, KineticSOL starts the listener and opens directly in the system tray without showing the window.</property>
                                <property name="activatable-widget">start_hidden_switch</property>
                                <child type="suffix">
                                  <object class="GtkSwitch" id="start_hidden_switch">
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Listen port</property>
                                <property name="subtitle" translatable="yes">The HTTP listener binds on all interfaces inside the sandbox.</property>
                                <child type="suffix">
                                  <object class="GtkSpinButton" id="port_spin">
                                    <property name="valign">center</property>
                                    <property name="numeric">True</property>
                                    <property name="adjustment">port_adjustment</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Shared token</property>
                                <property name="subtitle" translatable="yes">The Android app must send this value as a Bearer token.</property>
                                <child type="suffix">
                                  <object class="GtkEntry" id="token_entry">
                                    <property name="valign">center</property>
                                    <property name="hexpand">True</property>
                                    <property name="width-chars">28</property>
                                  </object>
                                </child>
                                <child type="suffix">
                                  <object class="GtkButton" id="rotate_token_button">
                                    <property name="valign">center</property>
                                    <property name="label" translatable="yes">Rotate</property>
                                  </object>
                                </child>
                                <child type="suffix">
                                  <object class="GtkButton" id="copy_token_button">
                                    <property name="valign">center</property>
                                    <property name="label" translatable="yes">Copy</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow" id="base_url_row">
                                <property name="title" translatable="yes">Base URL for Android</property>
                                <property name="subtitle" translatable="yes">The suggested base URL will appear here.</property>
                                <child type="suffix">
                                  <object class="GtkButton" id="copy_base_url_button">
                                    <property name="valign">center</property>
                                    <property name="label" translatable="yes">Copy</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <child>
                          <object class="AdwPreferencesGroup" id="diagnostics_group">
                            <property name="title" translatable="yes">Diagnostics</property>
                            <property name="description" translatable="yes">These rows expose the current listener state and the current logind capability check.</property>
                            <child>
                              <object class="AdwActionRow" id="listener_state_row">
                                <property name="title" translatable="yes">Listener state</property>
                                <property name="subtitle" translatable="yes">Not evaluated yet.</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow" id="tray_state_row">
                                <property name="title" translatable="yes">Plasma tray</property>
                                <property name="subtitle" translatable="yes">Tray integration inactive. It will activate when the app is hidden in background mode.</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow" id="power_state_row">
                                <property name="title" translatable="yes">Power backend</property>
                                <property name="subtitle" translatable="yes">Not evaluated yet.</property>
                                <child type="suffix">
                                  <object class="GtkButton" id="refresh_power_button">
                                    <property name="valign">center</property>
                                    <property name="label" translatable="yes">Refresh</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow" id="endpoint_row">
                                <property name="title" translatable="yes">Remote API</property>
                                <property name="subtitle" translatable="yes">The endpoint details will appear here.</property>
                                <child type="suffix">
                                  <object class="GtkButton" id="copy_curl_button">
                                    <property name="valign">center</property>
                                    <property name="label" translatable="yes">Copy curl</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow" id="last_request_row">
                                <property name="title" translatable="yes">Last remote command</property>
                                <property name="subtitle" translatable="yes">No remote commands received yet.</property>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </property>
              </object>
            </property>
          </object>
        </property>
      </object>
    </property>
  </template>
  <menu id="primary_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">_Show Diagnostics</attribute>
        <attribute name="action">win.show-diagnostics</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_About KineticSOL</attribute>
        <attribute name="action">app.about</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_Quit</attribute>
        <attribute name="action">app.quit</attribute>
      </item>
    </section>
  </menu>
</interface>
