<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>dev.neikon.kinetic_sol</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>KineticSOL</name>
  <summary>Remote Linux power agent</summary>
  <description>
    <p>KineticSOL is a Linux companion app for Kinetic WOL on Android that listens for trusted commands on the local network.</p>
    <p>It provides a GTK4 and libadwaita interface, exposes a local network endpoint and attempts to power off the host through systemd-logind without relying on interactive sudo.</p>
    <p>It is designed to work together with the Kinetic WOL Android app as its Linux-side companion.</p>
  </description>

  <developer id="dev.neikon">
    <name>neikon</name>
  </developer>

  <url type="homepage">https://github.com/Neikon/kinetic_sol</url>
  <url type="vcs-browser">https://github.com/Neikon/kinetic_sol</url>
  <url type="bugtracker">https://github.com/Neikon/kinetic_sol/issues</url>
  <url type="help">https://github.com/Neikon/kinetic_wol.git</url>

  <translation type="gettext">kineticsol</translation>
  <launchable type="desktop-id">dev.neikon.kinetic_sol.desktop</launchable>
  <content_rating type="oars-1.1" />

  <branding>
    <color type="primary" scheme_preference="light">#5d7cff</color>
    <color type="primary" scheme_preference="dark">#9ad8ff</color>
  </branding>

  <releases>
    <release version="26.04.19.1" date="2026-04-19">
      <url type="details">https://github.com/Neikon/kinetic_sol</url>
      <description translate="no">
        <p>Date-based release aligned with the new <code>YY.MM.DD.counter</code> versioning scheme.</p>
        <ul>
          <li>The app now uses an always-on listener model with simpler setup and fewer toggles.</li>
          <li>Background mode and Plasma tray integration are now available for easier long-running use.</li>
          <li>The About dialog includes in-app release notes for the current version.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.0" date="2026-04-18">
      <url type="details">https://github.com/Neikon/kinetic_sol</url>
      <description translate="no">
        <p>First functional release of the Linux-side Kinetic WOL companion.</p>
        <ul>
          <li>Remote listener, token handling and Android companion setup are now usable end to end.</li>
          <li>The app exposes diagnostics, base URL helpers and quick-copy actions for testing.</li>
        </ul>
      </description>
    </release>
  </releases>

</component>
